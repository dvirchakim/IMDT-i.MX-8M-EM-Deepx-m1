		pinctrl-0 = <0x85>;
		regulator-name = "VSD_3V3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		gpio = <0x31 0x13 0x00>;
		enable-active-high;
		phandle = <0x41>;
	};

