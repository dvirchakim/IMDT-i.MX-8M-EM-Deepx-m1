	regulator-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "REG_3V3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		regulator-always-on;
		phandle = <0x6b>;
	};


        /* M.2 B-slot card power enable (active-low GPIO) */
        regulator-m2b-power {
                compatible = "regulator-fixed";
                regulator-name = "M2B_CARD_PWR";
                regulator-min-microvolt = <3300000>;
                regulator-max-microvolt = <3300000>;
                gpio = <0x6a 0x04 0x01>;
                enable-active-low;
                regulator-boot-on;
                regulator-always-on;
                phandle = <0x1ff>;
        };

	regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "REG_1v8";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		regulator-always-on;
		phandle = <0x104>;
	};

	regulator-usdhc2 {
